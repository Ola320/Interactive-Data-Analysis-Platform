<UserControl x:Class="DataAnalizer.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lucide="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900" Background="#f8fafc">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Content="Export Report" Background="White" BorderBrush="#e2e8f0" Foreground="#334155" Padding="15,8" CornerRadius="8" Cursor="Hand"/>
            <TextBlock Text="Dashboard Overview" FontSize="24" FontWeight="Bold" Foreground="#0f172a"/>
        </DockPanel>

        <!-- Upload Section -->
        <Border Grid.Row="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="25" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Upload Dataset" FontSize="16" FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,15"/>
                <Border AllowDrop="True" Drop="UploadBorder_Drop" Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="2" CornerRadius="12" Padding="40,30" BorderDashArray="4 4" Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Background="White" Width="64" Height="64" CornerRadius="32" Margin="0,0,0,15" HorizontalAlignment="Center" Effect="{StaticResource DropShadow}">
                            <lucide:PackIconLucide Kind="UploadCloud" Foreground="#4f46e5" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="UploadStatusText" Text="Click or drag and drop to upload" FontWeight="Medium" Foreground="#334155" HorizontalAlignment="Center"/>
                        <TextBlock Text="CSV files only (Max 50MB)" FontSize="12" Foreground="#64748b" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <ProgressBar x:Name="UploadProgressBar" Height="6" Visibility="Collapsed" Margin="0,15,0,0" Foreground="#4f46e5" BorderThickness="0" Background="#e2e8f0"/>
            </StackPanel>
        </Border>

        <!-- KPI Cards -->
        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#eef2ff" CornerRadius="8" Width="48" Height="48" VerticalAlignment="Top" Margin="0,0,15,0">
                        <lucide:PackIconLucide Kind="Home" Foreground="#4f46e5" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Total Offers" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtTotalOffers" Text="-" Foreground="#0f172a" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#eef2ff" CornerRadius="8" Width="48" Height="48" VerticalAlignment="Top" Margin="0,0,15,0">
                        <lucide:PackIconLucide Kind="Tag" Foreground="#4f46e5" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Avg Price" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtAvgPrice" Text="-" Foreground="#0f172a" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#eef2ff" CornerRadius="8" Width="48" Height="48" VerticalAlignment="Top" Margin="0,0,15,0">
                        <lucide:PackIconLucide Kind="TrendingUp" Foreground="#4f46e5" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Median Price" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtMedianPrice" Text="-" Foreground="#0f172a" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#eef2ff" CornerRadius="8" Width="48" Height="48" VerticalAlignment="Top" Margin="0,0,15,0">
                        <lucide:PackIconLucide Kind="Grid" Foreground="#4f46e5" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Avg Price / m²" Foreground="#64748b" FontSize="13" FontWeight="Medium"/>
                        <TextBlock x:Name="TxtAvgPricePerSqm" Text="-" Foreground="#0f172a" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Charts -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Top Cities by Price/m²" FontSize="16" FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,15"/>
                    <lvc:CartesianChart x:Name="BarChartCities" Height="250"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock Text="Room Distribution" FontSize="16" FontWeight="SemiBold" Foreground="#1e293b" Margin="0,0,0,15"/>
                    <lvc:PieChart x:Name="PieChartRooms" Height="250"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    <UserControl.Resources>
        <DropShadowEffect x:Key="DropShadow" BlurRadius="10" ShadowDepth="2" Color="#000000" Opacity="0.05"/>
    </UserControl.Resources>
</UserControl>
