<UserControl x:Class="DataAnalizer.Views.CityDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lucide="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900" Background="#f8fafc">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="City Lookup" FontSize="24" FontWeight="Bold" Foreground="#0f172a"/>
            <TextBlock Text="Search for specific city metrics and real estate data." FontSize="14" Foreground="#64748b" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="#e2e8f0" BorderThickness="1"  Padding="25" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Background="#f1f5f9"  Height="45" Padding="15,0" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <lucide:PackIconLucide Kind="Search" Foreground="#94a3b8" Width="20" Height="20"/>
                        <TextBox x:Name="TxtSearchCity" BorderThickness="0" Background="Transparent" Foreground="#334155" FontSize="14" Margin="15,0,0,0" Width="400" VerticalAlignment="Center" Text="Enter city name..."/>
                    </StackPanel>
                </Border>
                <Button Grid.Column="1" Content="Search" Click="BtnSearch_Click" Background="#4f46e5" Foreground="White" BorderThickness="0" Padding="30,0"  Cursor="Hand" FontSize="14" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- Results Area -->
        <StackPanel x:Name="ResultsPanel" Grid.Row="2" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Border Background="#e0e7ff"  Width="40" Height="40" Margin="0,0,15,0">
                    <lucide:PackIconLucide Kind="MapPin" Foreground="#4f46e5" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtResultCityName" Text="City Name" FontSize="20" FontWeight="Bold" Foreground="#0f172a"/>
                    <TextBlock Text="Market Overview" FontSize="13" Foreground="#64748b"/>
                </StackPanel>
            </StackPanel>

            <UniformGrid Columns="3">
                <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1"  Padding="25" Margin="0,0,20,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,15">
                            <lucide:PackIconLucide DockPanel.Dock="Right" Kind="Home" Foreground="#818cf8" Width="20" Height="20"/>
                            <TextBlock Text="Total Listings" Foreground="#64748b" FontSize="14" FontWeight="Medium"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtResultTotalListings" Text="0" FontSize="32" FontWeight="Bold" Foreground="#0f172a"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1"  Padding="25" Margin="0,0,20,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,15">
                            <lucide:PackIconLucide DockPanel.Dock="Right" Kind="TrendingUp" Foreground="#10b981" Width="20" Height="20"/>
                            <TextBlock Text="Average Price" Foreground="#64748b" FontSize="14" FontWeight="Medium"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtResultAvgPrice" Text="$0" FontSize="32" FontWeight="Bold" Foreground="#0f172a"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#e2e8f0" BorderThickness="1"  Padding="25">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,15">
                            <lucide:PackIconLucide DockPanel.Dock="Right" Kind="MapPin" Foreground="#f59e0b" Width="20" Height="20"/>
                            <TextBlock Text="Avg Price / m²" Foreground="#64748b" FontSize="14" FontWeight="Medium"/>
                        </DockPanel>
                        <TextBlock x:Name="TxtResultAvgPriceSqm" Text="$0" FontSize="32" FontWeight="Bold" Foreground="#0f172a"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
        
        <TextBlock x:Name="TxtError" Grid.Row="3" Text="" Foreground="#ef4444" FontSize="14" Margin="0,10,0,0" Visibility="Collapsed"/>
    </Grid>
</UserControl>
