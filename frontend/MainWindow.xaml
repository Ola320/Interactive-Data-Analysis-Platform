<Window x:Class="DataAnalizer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lucide="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Real Estate Data Platform"
        Height="768" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#f8fafc"
        FontFamily="Segoe UI">

    <!-- Styles -->
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1e293b"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0f172a" CornerRadius="0,20,20,0" Margin="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                    <lucide:PackIconLucide Kind="Building2" Foreground="#4f46e5" Width="28" Height="28"/>
                    <TextBlock Text="RealData" Foreground="White" FontSize="22" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="15,20,15,0">
                    <TextBlock Text="MAIN MENU" Foreground="#64748b" FontSize="11" FontWeight="Bold" Margin="10,0,0,10"/>

                    <Button x:Name="BtnDashboard" Click="BtnDashboard_Click" Style="{StaticResource NavButtonStyle}" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <lucide:PackIconLucide Kind="LayoutDashboard" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnHistory" Click="BtnHistory_Click" Style="{StaticResource NavButtonStyle}" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <lucide:PackIconLucide Kind="History" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="History &amp; Logs" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnCityLookup" Click="BtnCityLookup_Click" Style="{StaticResource NavButtonStyle}" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <lucide:PackIconLucide Kind="MapPin" Width="18" Height="18" Margin="0,0,10,0"/>
                            <TextBlock Text="City Lookup" FontSize="14"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Pro Plan Banner -->
                <Border Grid.Row="2" Background="#1e293b" CornerRadius="12" Margin="15,0,15,20" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Pro Plan" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Unlock all features" Foreground="#94a3b8" FontSize="12" Margin="0,2,0,10"/>
                        <Button Content="Upgrade" Background="#4f46e5" Foreground="White" BorderThickness="0" Padding="0,6" Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                <Grid Margin="30,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Border Background="#f1f5f9" CornerRadius="8" Width="400" HorizontalAlignment="Left" Height="36" Padding="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <lucide:PackIconLucide Kind="Search" Foreground="#94a3b8" Width="16" Height="16"/>
                            <TextBox BorderThickness="0" Background="Transparent" Foreground="#334155" Margin="10,0,0,0" Width="350" VerticalAlignment="Center" Text="Search across reports, cities, or IDs..."/>
                        </StackPanel>
                    </Border>

                    <!-- User Profile -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <lucide:PackIconLucide Kind="Bell" Foreground="#64748b" Width="20" Height="20" Margin="0,0,20,0" Cursor="Hand"/>
                        <Border Width="1" Height="30" Background="#e2e8f0" Margin="0,0,20,0"/>
                        <Border Background="#e0e7ff" CornerRadius="16" Width="32" Height="32" Margin="0,0,10,0">
                            <TextBlock Text="W" Foreground="#4f46e5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Welcome, Admin" Foreground="#334155" FontWeight="Medium" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dynamic View Area -->
            <ContentControl x:Name="MainContentControl" Grid.Row="1" Margin="30"/>
        </Grid>
    </Grid>
</Window>
